{
    "name": "project-steward",
    "displayName": "Project Steward",
    "description": "Organize local, SSH, and Dev Container projects in a synchronized project steward.",
    "version": "1.1.8",
    "publisher": "hzcheng",
    "license": "MIT",
    "icon": "media/extension_icon.png",
    "engines": {
        "vscode": "^1.51.0"
    },
    "extensionKind": [
        "workspace",
        "ui"
    ],
    "categories": [
        "Other"
    ],
    "activationEvents": [
        "*"
    ],
    "main": "./dist/dashboard",
    "repository": {
        "type": "git",
        "url": "https://github.com/hzcheng/project-steward.git"
    },
    "capabilities": {
        "untrustedWorkspaces": {
            "supported": true
        }
    },
    "contributes": {
        "commands": [
            {
                "command": "projectSteward.open",
                "title": "Project Steward: Open"
            },
            {
                "command": "projectSteward.addGroup",
                "title": "Project Steward: Add Group"
            },
            {
                "command": "projectSteward.removeGroup",
                "title": "Project Steward: Remove Group"
            },
            {
                "command": "projectSteward.addProject",
                "title": "Project Steward: Add Project"
            },
            {
                "command": "projectSteward.saveProject",
                "title": "Project Steward: Save Project"
            },
            {
                "command": "projectSteward.removeProject",
                "title": "Project Steward: Remove Project"
            },
            {
                "command": "projectSteward.editProjects",
                "title": "Project Steward: Edit Projects"
            },
            {
                "command": "projectSteward.addProjectsFromFolder",
                "title": "Project Steward: Add Projects from Folder"
            }
        ],
        "keybindings": [
            {
                "command": "projectSteward.open",
                "key": "ctrl+f1",
                "mac": "cmd+f1"
            }
        ],
        "configuration": {
            "type": "object",
            "title": "Project Steward",
            "properties": {
                "projectSteward.projectData": {
                    "type": [
                        "array",
                        "null"
                    ],
                    "markdownDescription": "Stores the Project Steward data if the ```projectSteward.storeProjectsInSettings``` option is set to ```true```. The raw data can be edited by using the command ```Project Steward: Edit Projects```.",
                    "default": null
                },
                "projectSteward.searchIsActiveByDefault": {
                    "type": "boolean",
                    "default": true
                },
                "projectSteward.customCss": {
                    "type": "string",
                    "markdownDescription": "Custom CSS rules to be injected into the Project Steward can be placed here. Note that this will not be sanitized!",
                    "default": null
                },
                "projectSteward.recentColors": {
                    "type": "array",
                    "markdownDescription": "Stores the recently used colors if the ```projectSteward.storeProjectsInSettings``` option is set to ```true```.",
                    "default": null
                },
                "projectSteward.storeProjectsInSettings": {
                    "type": "boolean",
                    "default": true,
                    "markdownDescription": "If set to ```true```, the Project Steward data is saved in the user settings and can be synced using the ```Settings Sync``` extension to multiple devices. NOTE: This disables the possibility of having varying Project Steward data on these devices. **(VSCode restart required)**"
                },
                "projectSteward.maxVisibleAiSessions": {
                    "type": "number",
                    "default": 3,
                    "minimum": 1,
                    "markdownDescription": "Maximum number of AI session rows visible in an expanded project card before the session list scrolls."
                },
                "projectSteward.displayProjectPath": {
                    "type": "boolean",
                    "default": true
                },
                "projectSteward.prependVscodeUrlToWslRemotes": {
                    "type": "boolean",
                    "default": true
                },
                "projectSteward.projectTileWidth": {
                    "description": "In px, default: 350",
                    "type": "number",
                    "default": 350
                },
                "projectSteward.recentColorsToRemember": {
                    "type": "number",
                    "default": 15
                },
                "projectSteward.openOnStartup": {
                    "type": "string",
                    "default": "empty workspace",
                    "markdownDescription": "Note: The ```empty workspace``` option takes only effect if [Workbench: Startup Editor](#workbench.startupEditor) is to ```none``` or a ```welcomePage``` option.",
                    "enum": [
                        "always",
                        "empty workspace",
                        "never"
                    ]
                },
                "projectSteward.showAddGroupButtonTile": {
                    "type": "boolean",
                    "markdownDescription": "If set to ```false```, the '+ New Group' tile is hidden. Groups can be added by using the Command Palette (default ```F1```) with 'Project Steward: Add Group' action. The Project Steward needs to be refreshed for the changes to take effect.",
                    "default": true
                },
                "projectSteward.customProjectCardBackground": {
                    "type": "string",
                    "default": null
                },
                "projectSteward.customProjectNameColor": {
                    "type": "string",
                    "default": null
                },
                "projectSteward.customProjectPathColor": {
                    "type": "string",
                    "default": null
                },
                "projectSteward.applyProjectColorToWindow": {
                    "type": "boolean",
                    "default": false,
                    "markdownDescription": "If set to ```true```, Project Steward applies the saved project color to the current VS Code window by writing workspace ```workbench.colorCustomizations``` values for title bar, activity bar, and status bar."
                }
            }
        },
        "views": {
            "project-steward": [
                {
                    "type": "webview",
                    "id": "projectSteward.steward",
                    "name": "Project Steward",
                    "icon": "media/icon.svg",
                    "visibility": "visible",
                    "contextualTitle": "Project Steward"
                }
            ]
        },
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "project-steward",
                    "title": "Project Steward",
                    "icon": "media/icon.svg"
                }
            ]
        }
    },
    "scripts": {
        "vscode:prepublish": "webpack --mode production && npx gulp --production",
        "webpack": "webpack --mode development",
        "webpack-dev": "webpack --mode development --watch",
        "test-compile": "tsc -p ./",
        "test:safety": "npm run test-compile && node scripts/run-ai-session-safety-checks.js",
        "test:release-notes": "node scripts/run-release-notes-checks.js",
        "spike:attention:compile": "tsc -p spikes/attention-local-bridge/tsconfig.json",
        "spike:attention:test": "npm run spike:attention:compile && node scripts/run-attention-local-bridge-spike-checks.js",
        "spike:attention:bundle": "webpack --config spikes/attention-local-bridge/webpack.config.js --mode production",
        "spike:attention:package": "npm run spike:attention:test && npm run spike:attention:bundle && node spikes/attention-local-bridge/scripts/package.js",
        "lint": "tslint -p ./",
        "install-local": "./scripts/build-test-package-install.sh",
        "publish-marketplace": "./scripts/publish-marketplace.sh"
    },
    "devDependencies": {
        "@types/mocha": "^8.0.4",
        "@types/node": "^14.14.8",
        "@types/vscode": "^1.51.0",
        "gulp": "^4.0.2",
        "gulp-clean-css": "^4.3.0",
        "gulp-mode": "^1.1.0",
        "gulp-sass": "^5.0.0",
        "sass": "^1.56.0",
        "ts-loader": "^6.2.2",
        "tslint": "^6.1.3",
        "typescript": "^4.0.5",
        "webpack": "^5.74.0",
        "webpack-cli": "^4.10.0"
    },
    "dependencies": {
        "dom-autoscroller": "^2.3.4",
        "dragula": "^3.7.3",
        "fitty": "^2.3.5"
    }
}
